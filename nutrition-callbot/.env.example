# ============================================
# Legal CallBot — Environment Variables
# ============================================
# Copy this file to .env and fill in values

# --- Service Ports ---
GATEWAY_PORT=8000
ASR_PORT=50051
BRAIN_PORT=50052
TTS_PORT=50053
WEB_PORT=3000

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Debug ---
DEBUG=true
LOG_LEVEL=INFO

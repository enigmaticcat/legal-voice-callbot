# ============================================
# Nutrition CallBot — Environment Variables
# ============================================
# Copy this file to .env and fill in values

# --- Service Ports ---
GATEWAY_PORT=8000
ASR_PORT=50051
BRAIN_PORT=50052
TTS_PORT=50053
WEB_PORT=3000

# --- Local LLM Server ---
LLM_BASE_URL=http://llm:8000/v1
LLM_MODEL=Qwen/Qwen3-4B-Instruct-2507
LLM_API_KEY=local
LLM_TEMPERATURE=0.3

# --- Redis Cache ---
REDIS_URL=redis://redis:6379
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_REQUIRED=true
RETRIEVAL_CACHE_TTL_SECONDS=86400
CORPUS_VERSION=nutrition-v1
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_COLLECTION=nutrition_retrieval_cache
SEMANTIC_CACHE_THRESHOLD=0.90
SEMANTIC_CACHE_TTL_SECONDS=604800
TTS_CACHE_ENABLED=true
TTS_CACHE_REQUIRED=true
TTS_CACHE_TTL_SECONDS=604800
TTS_CACHE_MAX_BYTES=8000000
TTS_CACHE_VERSION=v1

# --- Brain Models (downloaded and executed locally) ---
EMBEDDING_MODEL=AITeamVN/Vietnamese_Embedding
RERANKER_MODEL=thanhtantran/Vietnamese_Reranker

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Debug ---
DEBUG=true
LOG_LEVEL=INFO

# --- Qdrant Snapshot Restore (Docker) ---
QDRANT_COLLECTION=nutrition_articles
QDRANT_SNAPSHOT_FILE=nutrition_articles.snapshot
QDRANT_SNAPSHOT_PRIORITY=snapshot

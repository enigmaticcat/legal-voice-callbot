---
title: Nutrition Callbot — System Architecture
---

flowchart TD
    subgraph CLIENT["Web Client (React :3000)"]
        UI["Push-to-talk / VAD UI\nApp.jsx"]
        WA["Web Audio API\n48kHz mic capture\n→ downsample 16kHz PCM"]
        AP["Audio Player\nPCM 24kHz playback"]
        WH["useWebSocket hook\nbinary + JSON events"]
        UI --> WA
        UI --> AP
        UI <--> WH
    end

    subgraph GATEWAY["Gateway (FastAPI :8000)"]
        WS["/ws/voice\nWebSocket endpoint"]
        ORCH["Orchestrator\nHTTP pipeline\nbrain_producer ‖ tts_consumer\nasyncio.Queue(maxsize=4)"]
        MEM["SessionMemory\nRedis-backed\nLua atomic append+trim\nmax 3 raw turns"]
        VAD_W["VAD Worker\nWebSocket → ASR /ws/vad\nbarge-in cancel"]
        WS --> ORCH
        WS <--> VAD_W
        ORCH <--> MEM
    end

    subgraph ASR_SVC["ASR Service (:50051)"]
        ASR_HTTP["POST /transcribe\nbatch mode (PTT)"]
        ASR_VAD["WS /ws/transcribe/vad\nstreaming VAD mode"]
        TRANS["Transcriber\nsherpa-onnx OfflineRecognizer\nZipFormer-RNNT\n16kHz → text"]
        VAD_DET["VAD Detector\nSilero VAD\n512-sample windows (32ms)\nspeech_start / segment events"]
        ASR_HTTP --> TRANS
        ASR_VAD --> VAD_DET
        VAD_DET -->|"float32 segments"| TRANS
    end

    subgraph BRAIN_SVC["Brain Service (:50052)"]
        BRAIN_HTTP["POST /think/stream\nNDJSON streaming"]
        SUMM["POST /summarize\nGemini summarize old turns"]
        QE["Query Expander\nalias dict → formal terms\n(bà bầu → phụ nữ mang thai, ...)"]
        RAG["RAG Pipeline\nE5-Large-instruct 1024-dim\n→ Qdrant top-8\n→ CrossEncoder rerank → top-5"]
        LLM["LLM Client\nGemini 2.5 Flash\nasync streaming\ntimeout: 15s per chunk"]
        CHUNKER["Brain Chunker\nsplit tại .!? ≥20 chars\nfallback: word boundary"]
        PROMPT["Prompt Builder\nSystem prompt + few-shot\n+ RAG context + history"]
        BRAIN_HTTP --> QE --> RAG --> PROMPT --> LLM --> CHUNKER
        SUMM --> LLM
    end

    subgraph TTS_SVC["TTS Service (:50053)"]
        TTS_HTTP["POST /speak/stream\nPCM streaming"]
        TTS_CANCEL["POST /cancel\nsession cancel event"]
        TTS_CHUNK["TTS Chunker\nword-safe split ≥80 chars"]
        SYNTH["Synthesizer\nVieNeu-TTS 0.3B GGUF\nllama-cpp-python\n24kHz mono float32 → int16\nSemaphore(1) serialize"]
        TTS_HTTP --> TTS_CHUNK --> SYNTH
        TTS_CANCEL --> SYNTH
    end

    subgraph DATA["Data Layer"]
        QDRANT[("Qdrant\nLocal embedded\n~270k vectors\n1024-dim")]
        REDIS[("Redis\nsession:{id}:turns\nsession:{id}:summary\nTTL 1800s")]
    end

    %% Client ↔ Gateway
    WH <-->|"WebSocket\nbinary PCM + JSON"| WS

    %% PTT flow
    ORCH -->|"POST /transcribe\nPCM int16 16kHz"| ASR_HTTP
    ASR_HTTP -->|"{ text, confidence }"| ORCH

    %% VAD flow
    VAD_W <-->|"WebSocket\nPCM chunks\nspeech_start / transcript"| ASR_VAD

    %% Brain flow
    ORCH -->|"POST /think/stream\nquery + history"| BRAIN_HTTP
    BRAIN_HTTP -->|"NDJSON chunks\n{ text, is_final, timing }"| ORCH

    %% TTS flow
    ORCH -->|"POST /speak/stream\ntext segment"| TTS_HTTP
    TTS_HTTP -->|"PCM int16 24kHz\n~4800 bytes/chunk"| ORCH

    %% Summarize
    MEM -->|"POST /summarize\nold turns"| SUMM

    %% Data
    RAG <-->|"embed + search\nqdrant_client"| QDRANT
    MEM <-->|"SETEX / GET\nLua eval"| REDIS

    %% Audio output
    ORCH -->|"audio_chunk events\nbinary PCM"| WS
    WS -->|"binary PCM 24kHz"| WH
    WH -->|"playPcm()"| AP

    %% Barge-in
    VAD_W -->|"speech_start\n→ cancel task"| ORCH
    ORCH -->|"POST /cancel"| TTS_CANCEL

    %% Styling
    classDef service fill:#1e3a5f,stroke:#4a9eff,color:#fff
    classDef data fill:#2d4a1e,stroke:#6abf40,color:#fff
    classDef client fill:#3a1e5f,stroke:#a04aff,color:#fff
    classDef gateway fill:#5f3a1e,stroke:#ff944a,color:#fff

    class ASR_SVC,BRAIN_SVC,TTS_SVC service
    class DATA data
    class CLIENT client
    class GATEWAY gateway

flowchart TB
    subgraph Sequential["Pipeline tuần tự"]
        direction LR
        SeqLLM["LLM sinh toàn bộ<br/>câu trả lời"]
        SeqFull["Văn bản hoàn chỉnh"]
        SeqTTS["TTS tổng hợp văn bản"]
        SeqAudio["Âm thanh đầu tiên"]

        SeqLLM --> SeqFull
        SeqFull --> SeqTTS
        SeqTTS --> SeqAudio
    end

    subgraph Streaming["Pipeline streaming song song"]
        direction LR
        Qwen["Qwen sinh token<br/>theo luồng"]
        BrainChunk["Brain gom token thành text chunk<br/>ngưỡng xử lý 40 ký tự"]
        GatewayBuffer["Gateway cộng dồn<br/>text chunk"]
        Split{"Gặp dấu câu sau 40 ký tự<br/>hoặc buffer đạt 200 ký tự?"}
        Wait["Tiếp tục tích lũy"]
        Segment["Làm sạch đoạn văn bản"]
        Queue[["Hàng đợi TTS<br/>tối đa 4 phần tử"]]
        TTS["VieNeu-TTS"]
        PCM["PCM int16 24 kHz<br/>theo frame"]
        EventQueue[["Hàng đợi sự kiện"]]
        Browser["Trình duyệt lập lịch<br/>phát nối tiếp"]

        Qwen --> BrainChunk
        BrainChunk --> GatewayBuffer
        GatewayBuffer --> Split
        Split -->|"Chưa đủ"| Wait
        Wait --> GatewayBuffer
        Split -->|"Đủ điều kiện"| Segment
        Segment --> Queue
        Queue --> TTS
        TTS --> PCM
        PCM --> EventQueue
        EventQueue --> Browser
    end

    subgraph BargeIn["Luồng barge-in"]
        direction LR
        UserSpeech["Người dùng bắt đầu nói"]
        VAD["Silero VAD phát hiện<br/>speech_start"]
        GatewayCancel["Gateway hủy task<br/>phản hồi hiện tại"]
        CancelTTS["Gửi yêu cầu hủy TTS"]
        InterruptedEvent["Gửi sự kiện bot_interrupted"]
        ClearPlayback["Trình duyệt dừng các nguồn<br/>audio đã lập lịch"]
        NewTurn["Thu nhận lượt nói mới"]

        UserSpeech --> VAD
        VAD --> GatewayCancel
        GatewayCancel --> CancelTTS
        GatewayCancel --> InterruptedEvent
        InterruptedEvent --> ClearPlayback
        ClearPlayback --> NewTurn
    end

    GatewayCancel -.->|"Dừng producer"| Qwen
    CancelTTS -.->|"Dừng consumer"| TTS

    SeqAudio --> Compare{"So sánh thời gian<br/>đến âm thanh đầu tiên"}
    Browser --> Compare
    Compare --> Result["Streaming giảm TTFA vì không phải<br/>chờ sinh toàn bộ câu trả lời"]

    classDef sequential fill:#fee2e2,stroke:#dc2626,color:#450a0a;
    classDef streaming fill:#dcfce7,stroke:#16a34a,color:#052e16;
    classDef decision fill:#fef3c7,stroke:#d97706,color:#451a03;
    classDef result fill:#dbeafe,stroke:#2563eb,color:#172554;
    classDef interrupt fill:#fce7f3,stroke:#db2777,color:#500724;

    class SeqLLM,SeqFull,SeqTTS,SeqAudio sequential;
    class Qwen,BrainChunk,GatewayBuffer,Wait,Segment,Queue,TTS,PCM,EventQueue,Browser streaming;
    class Split,Compare decision;
    class Result result;
    class UserSpeech,VAD,GatewayCancel,CancelTTS,InterruptedEvent,ClearPlayback,NewTurn interrupt;

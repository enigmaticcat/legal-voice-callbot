flowchart TB
    subgraph Input["Chiều nhận dạng giọng nói"]
        direction LR
        Microphone["Microphone"]
        Capture["Thu âm tại trình duyệt"]
        Convert16["PCM 16-bit, đơn kênh, 16 kHz<br/>Gửi mỗi 100 ms"]
        VAD["Silero VAD chạy trên CPU<br/>Window 32 ms, khoảng lặng 500 ms"]
        SpeechStart["Sự kiện speech_start"]
        SpeechSegment["Đoạn tiếng nói hoàn chỉnh"]
        Zipformer["Zipformer–RNN-T<br/>Nhận dạng offline theo đoạn"]
        Transcript["Transcript"]

        Microphone --> Capture
        Capture --> Convert16
        Convert16 --> VAD
        VAD -.->|"Bắt đầu nói"| SpeechStart
        VAD -->|"Kết thúc khoảng lặng<br/>và đoạn nói ≥250 ms"| SpeechSegment
        SpeechSegment --> Zipformer
        Zipformer --> Transcript
    end

    subgraph Output["Chiều tổng hợp giọng nói"]
        direction LR
        TextStream["Luồng văn bản từ Qwen"]
        Clean["Làm sạch văn bản"]
        Segment["Chia đoạn theo dấu câu<br/>và ranh giới từ"]
        VieNeu["VieNeu-TTS"]
        PCM24["PCM 24 kHz"]
        AudioBuffer["Bộ đệm phát nối tiếp"]
        Speaker["Loa người dùng"]
        GatewayCancel["Gateway hủy task hiện tại<br/>và gọi yêu cầu hủy TTS"]
        BrowserReset["Sự kiện bot_interrupted<br/>xóa audio đã lập lịch"]

        TextStream --> Clean
        Clean --> Segment
        Segment --> VieNeu
        VieNeu --> PCM24
        PCM24 --> AudioBuffer
        AudioBuffer --> Speaker
        SpeechStart -.->|"Barge-in"| GatewayCancel
        GatewayCancel -.->|"Dừng infer_stream theo session"| VieNeu
        GatewayCancel -.-> BrowserReset
        BrowserReset -.-> AudioBuffer
    end

    classDef input fill:#dbeafe,stroke:#2563eb,color:#172554;
    classDef output fill:#dcfce7,stroke:#16a34a,color:#052e16;
    classDef model fill:#fef3c7,stroke:#d97706,color:#451a03;

    class Microphone,Capture,Convert16,VAD,SpeechStart,SpeechSegment,Transcript input;
    class TextStream,Clean,Segment,PCM24,AudioBuffer,Speaker,GatewayCancel,BrowserReset output;
    class Zipformer,VieNeu model;

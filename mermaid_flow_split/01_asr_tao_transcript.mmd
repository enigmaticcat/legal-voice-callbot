flowchart TD
    A([Người dùng nói])
    B[Giao diện thu âm]
    C[Bộ điều phối phiên]
    D[Mô-đun ASR]
    E[Phát hiện tiếng nói / VAD]
    F{Lượt nói đã hoàn chỉnh?}
    G[Tạo transcript]
    H[Bộ điều phối nhận transcript]
    I[Đọc lịch sử và tóm tắt phiên]
    J[Chuyển câu hỏi và ngữ cảnh phiên sang mô-đun xử lý hội thoại]

    A --> B
    B -->|Audio frames| C
    C -->|Audio stream + session id| D
    D --> E
    E --> F
    F -->|Chưa| E
    F -->|Rồi| G
    G -->|Transcript| H
    H --> I
    I --> J

    classDef start fill:#dcfce7,stroke:#16a34a,color:#111827;
    classDef process fill:#e8eefc,stroke:#64748b,color:#111827;
    classDef decision fill:#fef3c7,stroke:#ca8a04,color:#111827;
    classDef endnode fill:#dbeafe,stroke:#2563eb,color:#111827;

    class A start;
    class B,C,D,E,G,H,I process;
    class F decision;
    class J endnode;
